rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Validate transaction fields on write
      allow update: if request.auth != null
        && request.auth.uid == userId
        && validateUserData(request.resource.data);

      // AI Insights subcollection
      match /aiInsights/{insightId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validateUserData(data) {
  // Ensure profile fields are valid
  return data.keys().hasAny(['profile', 'transactions', 'goals', 'gamification', 'theme'])
    && (
      !('theme' in data) || data.theme in ['dark', 'light']
    );
}
